FROM golang:1.24-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -o /out/tunneld ./cmd/tunneld

FROM alpine:3.21

RUN adduser -D -H tunneld
USER tunneld

COPY --from=build /out/tunneld /usr/local/bin/tunneld

EXPOSE 8080
ENTRYPOINT ["tunneld"]
